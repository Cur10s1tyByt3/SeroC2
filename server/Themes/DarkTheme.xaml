<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Colors & Brushes ────────────────────────────────────────────── -->
    <!-- Window Backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0C0D18" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#111222" />
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#111222" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#0D0E1A" />
    <SolidColorBrush x:Key="AccentPanelBackgroundBrush" Color="#1A1E36" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0A0D1A" />

    <!-- Borders -->
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#2A2E50" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#1E2038" />
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#1A1C2E" />

    <!-- Text / Foreground -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#DDE0F0" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#606880" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#505878" />
    <SolidColorBrush x:Key="TextHighlightBrush" Color="#89dceb" />

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentBrush" Color="#4A85F5" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#6AABFF" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#7C5CE8" />
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4A85F5" Offset="0"/>
        <GradientStop Color="#7C5CE8" Offset="1"/>
    </LinearGradientBrush>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#22C55E" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="StatusErrorBrush" Color="#EF4444" />
    
    <!-- Context Menu Background -->
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#111222" />
    <SolidColorBrush x:Key="MenuBorderBrush" Color="#1E2038" />
    <SolidColorBrush x:Key="MenuItemHoverBrush" Color="#1A1C2E" />

    <!-- Shared Styles can be ported here incrementally -->
    <!-- TextBlocks -->
    <Style x:Key="TitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextHighlightBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StandardTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
    </Style>

</ResourceDictionary>
