<Window x:Class="SeroServer.UI.TikTokWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TikTok"
        Width="600" Height="580" MinWidth="460" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True" x:Name="RootBorder">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#f38ba8" Offset="0"/>
                        <GradientStop Color="#cba6f7" Offset="0.5"/>
                        <GradientStop Color="#89b4fa" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="♪" FontSize="15" Foreground="#f38ba8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="TikTok" FontSize="13" FontWeight="SemiBold" Foreground="#C0CCDD"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#404868"
                                   VerticalAlignment="Center" FontFamily="Segoe UI Mono" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMax" Content="☐" Width="30" Height="28" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="✕" Width="30" Height="28"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <TextBlock x:Name="TxtStatus" Text="Ready"
                           Foreground="#404868" FontSize="11" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="14,0"/>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,14">

                <!-- Session -->
                <Border Padding="14,12" CornerRadius="6" Margin="0,0,0,10"
                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="SESSION COOKIE" FontSize="9" FontWeight="Bold"
                                       Foreground="#C0f38ba8" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <Button Content="Detect on machine" Height="24" Padding="10,0"
                                    HorizontalAlignment="Right" Style="{StaticResource SBtn}"
                                    FontSize="10" Click="BtnDetect_Click"
                                    ToolTip="Ask the machine to find existing TikTok cookies in its browsers"/>
                        </Grid>
                        <TextBox x:Name="TxtCookie" Style="{StaticResource STxt}" Height="52"
                                 TextWrapping="Wrap" AcceptsReturn="True" FontSize="10"
                                 ToolTip="Paste: sessionid=...;  msToken=...;  tt_csrf_token=..."/>
                        <TextBlock Text="Tip: export cookies with EditThisCookie or Cookie-Editor in Chrome/Edge"
                                   Foreground="#353858" FontSize="10" FontFamily="Segoe UI" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Target type toggle -->
                <Border Padding="14,12" CornerRadius="6" Margin="0,0,0,10"
                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                    <StackPanel>
                        <TextBlock Text="TARGET TYPE" FontSize="9" FontWeight="Bold"
                                   Foreground="#C0f38ba8" FontFamily="Consolas" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbVideo" Content="Video / Post" IsChecked="True"
                                         Foreground="#DDE0F0" FontSize="12" Margin="0,0,20,0"
                                         GroupName="TargetType"/>
                            <RadioButton x:Name="RbLive"  Content="Livestream (room ID)"
                                         Foreground="#DDE0F0" FontSize="12"
                                         GroupName="TargetType"/>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,4" Style="{StaticResource SFieldLabel}">
                            <Run x:Name="RunIdLabel" Text="Video URL or ID"/>
                        </TextBlock>
                        <TextBox x:Name="TxtVideoId" Style="{StaticResource STxt}" FontSize="12"
                                 ToolTip="Full TikTok URL or numeric ID — works for videos and livestreams"/>
                    </StackPanel>
                </Border>

                <!-- Comment -->
                <Border Padding="14,12" CornerRadius="6" Margin="0,0,0,10"
                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                    <StackPanel>
                        <TextBlock Text="COMMENT" FontSize="9" FontWeight="Bold"
                                   Foreground="#C0f38ba8" FontFamily="Consolas" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtComment" Style="{StaticResource STxt}" Height="70"
                                 TextWrapping="Wrap" AcceptsReturn="True" FontSize="12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Post comment" Height="32" Padding="20,0" Margin="0,0,8,0"
                                    Style="{StaticResource SGreenBtn}" FontSize="12" Click="BtnPost_Click"/>
                            <TextBlock x:Name="TxtSentCount" Text="0 sent"
                                       Foreground="#505878" FontSize="11" FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Log -->
                <Border Padding="12,10" CornerRadius="6"
                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="LOG" FontSize="9" FontWeight="Bold"
                                       Foreground="#C0f38ba8" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <Button Content="Clear" Height="22" Padding="10,0" HorizontalAlignment="Right"
                                    Style="{StaticResource SBtn}" FontSize="9" Click="BtnClearLog_Click"/>
                        </Grid>
                        <Border Background="#05060E" CornerRadius="4" Height="120">
                            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="TxtLog"
                                         Background="Transparent" Foreground="#C8D0E8"
                                         FontFamily="Consolas" FontSize="11"
                                         BorderThickness="0" Padding="8,6"
                                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
