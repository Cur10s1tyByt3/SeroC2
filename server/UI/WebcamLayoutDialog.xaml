<Window x:Class="SeroServer.UI.WebcamLayoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Webcam Layout"
        Width="480" Height="340"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">

    <Border CornerRadius="10" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="36" Background="#111222"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="14,0">
                    <TextBlock Text="📐 Webcam Layout" FontSize="12" FontWeight="SemiBold"
                               Foreground="#89dceb" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" Width="28" Height="24"
                            Style="{StaticResource SRedBtn}" Cursor="Hand"
                            Click="Cancel_Click" FontSize="10" Padding="0"/>
                </Grid>
            </Border>

            <!-- Bottom bar: Remember + buttons -->
            <Border DockPanel.Dock="Bottom" Height="52" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <CheckBox x:Name="ChkRemember" Content="Remember my preference"
                              Foreground="#606888" FontSize="11" FontFamily="Segoe UI"
                              VerticalAlignment="Center" HorizontalAlignment="Left"
                              Style="{StaticResource SChk}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="CANCEL" Width="80" Height="28" Margin="0,0,8,0"
                                Style="{StaticResource SBtn}" Click="Cancel_Click"
                                FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                        <Button Content="OK" Width="80" Height="28"
                                Style="{StaticResource SGreenBtn}" Click="Ok_Click"
                                FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Layout cards -->
            <Grid Margin="20,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tile card -->
                <Border x:Name="CardTile" Grid.Column="0" CornerRadius="8"
                        BorderThickness="2" Cursor="Hand"
                        Background="#12142A" BorderBrush="#4A85F5"
                        MouseLeftButtonDown="CardTile_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Tile preview: 2x2 grid -->
                        <Canvas Width="120" Height="80" Margin="0,8,0,10">
                            <Rectangle Canvas.Left="2"  Canvas.Top="2"  Width="56" Height="36"
                                       Fill="#1A2040" Stroke="#4A85F5" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
                            <Rectangle Canvas.Left="62" Canvas.Top="2"  Width="56" Height="36"
                                       Fill="#1A2040" Stroke="#4A85F5" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
                            <Rectangle Canvas.Left="2"  Canvas.Top="42" Width="56" Height="36"
                                       Fill="#1A2040" Stroke="#4A85F5" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
                            <Rectangle Canvas.Left="62" Canvas.Top="42" Width="56" Height="36"
                                       Fill="#1A2040" Stroke="#4A85F5" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
                        </Canvas>
                        <TextBlock Text="Tile Windows" Foreground="#C0C8E8"
                                   FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- Cascade card -->
                <Border x:Name="CardCascade" Grid.Column="2" CornerRadius="8"
                        BorderThickness="2" Cursor="Hand"
                        Background="#12142A" BorderBrush="#1E2038"
                        MouseLeftButtonDown="CardCascade_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Cascade preview: stacked offset rectangles -->
                        <Canvas Width="120" Height="80" Margin="0,8,0,10">
                            <Rectangle Canvas.Left="2"  Canvas.Top="2"  Width="76" Height="52"
                                       Fill="#1A2040" Stroke="#7C5CE8" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
                            <Rectangle Canvas.Left="16" Canvas.Top="14" Width="76" Height="52"
                                       Fill="#1A2040" Stroke="#7C5CE8" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
                            <Rectangle Canvas.Left="30" Canvas.Top="26" Width="76" Height="52"
                                       Fill="#1A2040" Stroke="#7C5CE8" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
                        </Canvas>
                        <TextBlock Text="Cascade Windows" Foreground="#C0C8E8"
                                   FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>
            </Grid>

        </DockPanel>
    </Border>
</Window>
