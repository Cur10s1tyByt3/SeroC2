<Window x:Class="SeroServer.UI.WindowManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Window Manager" Width="900" Height="560" MinWidth="660" MinHeight="380"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">
    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#2A2E50" Offset="0"/><GradientStop Color="#141628" Offset="1"/></LinearGradientBrush></Border.BorderBrush>
        <Border.Effect><DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/></Border.Effect>
        <DockPanel>
            <!-- Top accent line -->
            <Rectangle DockPanel.Dock="Top" Height="2"><Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#4A85F5" Offset="0"/><GradientStop Color="#7C5CE8" Offset="1"/></LinearGradientBrush></Rectangle.Fill></Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe UI Emoji" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#4A85F5" Text="&#x1FA9F;"/>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#4A85F5" Margin="0,0,10,0" VerticalAlignment="Center" Text="Window Manager"/>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#8890B8" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCount" FontSize="11" Foreground="#3A4860" FontFamily="Consolas" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="&#x27F3;" Height="27" Width="30" Margin="0,0,4,0" Style="{StaticResource SBtn}" FontSize="14" Padding="0" Click="BtnRefresh_Click" ToolTip="Refresh"/>
                        <Button x:Name="BtnMax" Content="&#x2610;" Width="30" Height="27" Margin="0,0,4,0" Style="{StaticResource SBtn}" FontSize="12" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="&#x2715;" Width="30" Height="27" Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="#0E0F1E" BorderBrush="#181A28" BorderThickness="0,0,0,1" Padding="8,5">
                <DockPanel>
                    <!-- Search box -->
                    <Border DockPanel.Dock="Right" Background="#141526" BorderBrush="#252840" BorderThickness="1" CornerRadius="4" Padding="6,0" Margin="8,0,0,0" Width="180">
                        <DockPanel>
                            <TextBlock Text="🔍" FontSize="10" VerticalAlignment="Center" Foreground="#454870" Margin="0,0,4,0"/>
                            <TextBox x:Name="TxtSearch" Background="Transparent" Foreground="#CDD0E8" BorderThickness="0"
                                     FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"
                                     TextChanged="TxtSearch_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Grid>
                                                        <TextBlock Text="Search title, class, process..." Foreground="#353858" FontSize="11"
                                                                   VerticalAlignment="Center" FontFamily="Segoe UI"
                                                                   Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}"/>
                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DockPanel>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="👁 Show"     Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnShow_Click"     ToolTip="Show window"/>
                        <Button Content="🚫 Hide"     Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnHide_Click"     ToolTip="Hide window"/>
                        <Button Content="🎯 Focus"    Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnFocus_Click"    ToolTip="Bring to front"/>
                        <Button Content="▬ Min"       Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnMinimize_Click" ToolTip="Minimize"/>
                        <Button Content="□ Max"       Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnMaximize_Click2" ToolTip="Maximize"/>
                        <Button Content="↩ Restore"   Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnRestore_Click"  ToolTip="Restore"/>
                        <Rectangle Width="1" Fill="#252840" Margin="4,2,8,2"/>
                        <Button Content="✕ Close"     Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnClose_Click2"   ToolTip="Close (WM_CLOSE)"/>
                        <Button Content="💀 Kill"     Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SRedBtn}" Click="BtnKill_Click"  ToolTip="Kill process"/>
                        <Rectangle Width="1" Fill="#252840" Margin="4,2,8,2"/>
                        <Button Content="❄ Freeze"    Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnFreeze_Click"   ToolTip="Suspend process threads"/>
                        <Button Content="🔥 Unfreeze" Height="26" Padding="8,0" Margin="0,0,4,0" Style="{StaticResource SBtn}" Click="BtnUnfreeze_Click" ToolTip="Resume process threads"/>
                        <Rectangle Width="1" Fill="#252840" Margin="4,2,8,2"/>
                        <CheckBox x:Name="ChkAutoRefresh" Content="Auto 3s" Foreground="#8890B8" FontSize="11"
                                  VerticalAlignment="Center" Margin="0,0,0,0"
                                  Checked="ChkAutoRefresh_Changed" Unchecked="ChkAutoRefresh_Changed"
                                  ToolTip="Refresh window list every 3 seconds"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="26" Background="#0C0D18" BorderBrush="#181A28" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#353858" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9" Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.5"/></ControlTemplate></Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Data grid -->
            <DataGrid x:Name="GridWins" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#CDD0E8" BorderThickness="0"
                      RowBackground="Transparent" AlternatingRowBackground="#05101428"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#0C0E1A"
                      HeadersVisibility="Column" FontFamily="Segoe UI" FontSize="12"
                      SelectionMode="Extended" CanUserAddRows="False"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      EnableColumnVirtualization="True"
                      ScrollViewer.CanContentScroll="True"
                      ColumnHeaderStyle="{StaticResource SColHeader}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="&#x1F5BC; Show"     Click="BtnShow_Click"/>
                        <MenuItem Header="&#x1F6AB; Hide"     Click="BtnHide_Click"/>
                        <MenuItem Header="&#x1F3AF; Focus"    Click="BtnFocus_Click"/>
                        <MenuItem Header="&#x21A9; Restore"   Click="BtnRestore_Click"/>
                        <MenuItem Header="▬ Minimize"         Click="BtnMinimize_Click"/>
                        <MenuItem Header="□ Maximize"         Click="BtnMaximize_Click2"/>
                        <MenuItem Header="&#x2715; Close"     Click="BtnClose_Click2"/>
                        <MenuItem Header="&#x2620; Kill"      Click="BtnKill_Click"/>
                        <Separator/>
                        <MenuItem Header="&#x2744; Freeze"    Click="BtnFreeze_Click"/>
                        <MenuItem Header="&#x1F525; Unfreeze" Click="BtnUnfreeze_Click"/>
                        <Separator/>
                        <MenuItem Header="Copy Title"   Click="GridWins_CopyTitle_Click"/>
                        <MenuItem Header="Copy Handle"  Click="GridWins_CopyHandle_Click"/>
                        <MenuItem Header="Copy Process" Click="GridWins_CopyProcess_Click"/>
                        <Separator/>
                        <MenuItem Header="&#x1F504; Refresh"  Click="BtnRefresh_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <!-- Icon -->
                    <DataGridTemplateColumn Width="30" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="6,0"
                                       RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Visible dot -->
                    <DataGridTemplateColumn Header="●" Width="32" CanUserSort="True" SortMemberPath="Visible">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                                         Fill="{Binding VisibleColor}" ToolTip="{Binding VisibleStr}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="PROCESS" Binding="{Binding ProcessName}" Width="120" FontFamily="Consolas" FontSize="11"/>
                    <DataGridTextColumn Header="TITLE"   Binding="{Binding Title}"       Width="*"/>
                    <DataGridTextColumn Header="CLASS"   Binding="{Binding ClassName}"   Width="140"/>
                    <DataGridTextColumn Header="PID"     Binding="{Binding Pid}"         Width="60"  FontFamily="Consolas" FontSize="11"/>
                    <DataGridTextColumn Header="HANDLE"  Binding="{Binding HandleHex}"   Width="90"  FontFamily="Consolas" FontSize="11"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>
