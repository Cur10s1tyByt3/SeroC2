<Window x:Class="SeroServer.UI.KeyloggerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keylogger"
        Width="760" Height="560" MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#cba6f7" Offset="0"/>
                        <GradientStop Color="#89b4fa" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⌨" FontSize="15" Foreground="#cba6f7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Keylogger" FontSize="12" FontWeight="SemiBold" Foreground="#C0CCDD"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#404868"
                                   VerticalAlignment="Center" FontFamily="Segoe UI Mono" Margin="10,0,0,0"/>
                        <Border x:Name="BadgeRunning" Margin="10,0,0,0" CornerRadius="3"
                                Background="#1A0C2E" BorderBrush="#3A1A5E" BorderThickness="1"
                                Padding="6,2" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#cba6f7" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Effect><DropShadowEffect Color="#cba6f7" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="CAPTURING" Foreground="#cba6f7" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnStart" Content="▶ Start" Width="68" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="10" Click="BtnStart_Click"/>
                        <Button x:Name="BtnStop" Content="■ Stop" Width="62" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SRedBtn}" FontSize="10" Click="BtnStop_Click" IsEnabled="False"/>
                        <Button Content="⟳ Get" Width="54" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="10" Click="BtnGet_Click"/>
                        <Button Content="🗑 Clear" Width="60" Height="26" Margin="0,0,6,0"
                                Style="{StaticResource SBtn}" FontSize="10" Click="BtnClear_Click"/>
                        <Button Content="💾 Save" Width="56" Height="26" Margin="0,0,6,0"
                                Style="{StaticResource SBtn}" FontSize="10" Click="BtnSave_Click"/>
                        <Button Content="✕" Width="28" Height="26" FontSize="10"
                                Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <TextBlock x:Name="TxtStatus" Text="Ready — click Start to begin capturing"
                               Foreground="#404868" FontSize="11" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtChars" Text=""
                               Foreground="#303458" FontSize="10" FontFamily="Segoe UI Mono"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Log area -->
            <Border Background="#07080F" Margin="0">
                <Grid>
                    <TextBox x:Name="TxtLog"
                             Background="Transparent" Foreground="#C8D0E8"
                             FontFamily="Consolas" FontSize="12"
                             BorderThickness="0" Padding="14,10"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             AcceptsReturn="True"
                             CaretBrush="#cba6f7"/>
                    <StackPanel x:Name="PnlIdle" HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <TextBlock Text="⌨" FontSize="48" HorizontalAlignment="Center" Opacity="0.08"/>
                        <TextBlock Text="Click Start to begin capturing keystrokes"
                                   Foreground="#252848" FontSize="13" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Logs update automatically every 10 seconds"
                                   Foreground="#1E2038" FontSize="11" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </DockPanel>
    </Border>
</Window>
